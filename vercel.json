{
  "buildCommand": "npm run build --workspaces --if-present",
  "outputDirectory": "web/dist",
  "rewrites": [
    {
      "source": "/market/:path*",
      "destination": "/api/market?__coinburrow_path=market/:path*"
    },
    {
      "source": "/api/market/:path*",
      "destination": "/api/market?__coinburrow_path=market/:path*"
    },
    {
      "source": "/api/simulator/:path*",
      "destination": "/api/simulator?__coinburrow_path=simulator/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
